# Go
#################################################################
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (not strictly needed as Go uses go.mod, 
# but good to ignore if you ever use 'go mod vendor')
vendor/

# Go workspace file
go.work
go.work.sum

# Python / Conda
#################################################################
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env
.idea/
.vscode/
*.sqlite3

# Conda-specific
.conda/
conda-meta/

# Node / Vite
#################################################################
node_modules/
dist/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDEs
#################################################################
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
/backend_go/data
*.db
